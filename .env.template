# Sonos Radio Configuration
# Copy to SD card as ".env" and fill in your values.
# Device reads on boot, stores to flash. Card can be removed after.

# WiFi (required)
WIFI_SSID=
WIFI_PASS=

# Sonos speaker IP (optional — auto-discovered if omitted)
# SPEAKER_IP=192.168.1.100

# Default volume (0–100)
VOLUME=20

# Default station index (0-based, see station list in app_config.h)
# 0=NTS 1, 1=NTS 2, 2=SomaFM Drone Zone, 3=KEXP, 4=BBC Radio 6
STATION=0
