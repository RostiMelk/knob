# Sonos Radio Configuration
# Copy to SD card as ".env" and fill in your values.
# Device reads on boot, stores to flash. Card can be removed after.
#
# Voice mode requires an OpenAI API key (double-tap screen to activate).

# WiFi (required)
WIFI_SSID=
WIFI_PASS=

# Sonos speaker IP (optional — auto-discovered if omitted)
# SPEAKER_IP=192.168.1.100

# Default volume (0–100)
VOLUME=33

# Timezone (POSIX TZ string — default: Oslo CET/CEST)
# See: https://www.gnu.org/software/libc/manual/html_node/TZ-Variable.html
# TIMEZONE=CET-1CEST,M3.5.0,M10.5.0/3

# Default station index (0-based, see station list in app_config.h)
# 0=NTS 1, 1=NTS 2, 2=SomaFM Drone Zone, 3=KEXP, 4=BBC Radio 6
STATION=0

# OpenAI API key (optional — enables voice assistant via double-tap)
# OPENAI_API_KEY=sk-proj-...
