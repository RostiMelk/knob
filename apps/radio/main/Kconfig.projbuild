menu "Sonos Radio"

    config RADIO_WIFI_SSID
        string "Default WiFi SSID"
        default ""
        help
            Fallback SSID if nothing stored in NVS.

    config RADIO_WIFI_PASSWORD
        string "Default WiFi Password"
        default ""
        help
            Fallback password if nothing stored in NVS.

    config RADIO_WIFI_MAX_RETRIES
        int "WiFi connection retries before backoff"
        default 5
        range 1 20

    config RADIO_SONOS_SPEAKER_IP
        string "Sonos speaker IP address"
        default "192.168.1.100"
        help
            Hardcoded speaker IP for MVP. Will be replaced by SSDP discovery.

    config RADIO_SONOS_POLL_INTERVAL_MS
        int "Sonos state poll interval (ms)"
        default 2000
        range 1000 30000

    config RADIO_VOLUME_DEFAULT
        int "Default volume (0-100)"
        default 33
        range 0 100

    config RADIO_TIMEZONE
        string "POSIX timezone string"
        default "CET-1CEST,M3.5.0,M10.5.0/3"
        help
            POSIX TZ string for local time display. Default is Oslo (CET/CEST).
            See: https://www.gnu.org/software/libc/manual/html_node/TZ-Variable.html
            Examples:
              US Eastern:  EST5EDT,M3.2.0,M11.1.0
              US Pacific:  PST8PDT,M3.2.0,M11.1.0
              UK:          GMT0BST,M3.5.0/1,M10.5.0
              Japan:       JST-9

    config RADIO_OPENAI_API_KEY
        string "OpenAI API key for voice mode"
        default ""
        help
            API key for OpenAI Realtime API. Required for voice assistant.
            Set via .env file on SD card (OPENAI_API_KEY=sk-proj-...) or
            pass directly here for development.

endmenu
